NODE_ENV=development
PORT=4000

# URL completa do Postgres (backend é o único que pode acessar)
# Preferência de leitura: DATABASE_URL -> POSTGRES_URL -> POSTGRES_PRISMA_URL
# Supabase Pooler (recomendado): host do pooler + porta 6543 + sslmode=require
DATABASE_URL=postgres://postgres.PROJECT_REF:SUA_SENHA@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
POSTGRES_URL=postgres://postgres.PROJECT_REF:SUA_SENHA@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=SUA_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_APENAS_NO_BACKEND

FRONTEND_URL=http://localhost:3000

PG_POOL_MAX=3
PG_CONNECTION_TIMEOUT=20000
PG_IDLE_TIMEOUT=10000

# Compat (se você usa CORS_ORIGIN antigo)
CORS_ORIGIN=http://localhost:3000

# JWT do backend (NUNCA expor para o frontend via env)
JWT_SECRET=changeme-super-secret

# Regras de reserva e preço
RESERVATION_TTL_MIN=15
PRICE_CENTS=5500

# === Mercado Pago (TEST) ===
MP_ACCESS_TOKEN=TEST-REPLACE-ME
